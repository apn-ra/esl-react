# Copy to .env.live.local for local opt-in live FreeSWITCH harness runs.
# Do not commit .env.live.local or real credentials.

ESL_REACT_LIVE_TEST=1
ESL_REACT_LIVE_HOST=127.0.0.1
ESL_REACT_LIVE_PORT=8021
ESL_REACT_LIVE_PASSWORD=ClueCon
ESL_REACT_LIVE_API_COMMAND=status

# Enable only when your live target has a safe, predictable event source.
ESL_REACT_LIVE_EVENT_TEST=0
ESL_REACT_LIVE_EVENT_NAME=HEARTBEAT
ESL_REACT_LIVE_EVENT_TIMEOUT=25
# ESL_REACT_LIVE_EVENT_TRIGGER_API=

# Enable only for staging/lab manual reconnect recovery checks.
ESL_REACT_LIVE_MANUAL_RECONNECT_TEST=0
ESL_REACT_LIVE_MANUAL_DISCONNECT_TIMEOUT=45
ESL_REACT_LIVE_MANUAL_RECONNECT_TIMEOUT=60
ESL_REACT_LIVE_POST_RECONNECT_EVENT_TIMEOUT=25

# Enable only for staging/lab manual reconnect + post-reconnect api() checks.
ESL_REACT_LIVE_MANUAL_RECONNECT_API_TEST=0
ESL_REACT_LIVE_POST_RECONNECT_API_COMMAND=status
ESL_REACT_LIVE_POST_RECONNECT_API_TIMEOUT=6
