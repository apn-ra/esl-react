# Copy to .env.live.local for local opt-in live FreeSWITCH harness runs.
# Do not commit .env.live.local or real credentials.

ESL_REACT_LIVE_TEST=1
ESL_REACT_LIVE_HOST=127.0.0.1
ESL_REACT_LIVE_PORT=8021
ESL_REACT_LIVE_PASSWORD=ClueCon
ESL_REACT_LIVE_API_COMMAND=status

# Enable to validate the public runner seam plus lifecycle observation surfaces.
ESL_REACT_LIVE_RUNNER_TEST=0
# ESL_REACT_LIVE_RUNNER_ENDPOINT=live-freeswitch

# Enable only when your lab target can safely automate transport disruption and restore.
ESL_REACT_LIVE_RUNNER_RECONNECT_TEST=0
# ESL_REACT_LIVE_RECONNECT_DISRUPT_COMMAND=
# ESL_REACT_LIVE_RECONNECT_RESTORE_COMMAND=
ESL_REACT_LIVE_RECONNECT_DISCONNECT_TIMEOUT=20
ESL_REACT_LIVE_RECONNECT_TIMEOUT=30
ESL_REACT_LIVE_RECONNECT_DISRUPT_SETTLE_SECONDS=1
ESL_REACT_LIVE_RECONNECT_RESTORE_SETTLE_SECONDS=1

# Enable only when your live target has a safe, predictable event source.
ESL_REACT_LIVE_EVENT_TEST=0
ESL_REACT_LIVE_EVENT_NAME=HEARTBEAT
ESL_REACT_LIVE_EVENT_TIMEOUT=25
# ESL_REACT_LIVE_EVENT_TRIGGER_API=

# Enable only for one safe direct bgapi() compatibility check.
ESL_REACT_LIVE_BGAPI_TEST=0
ESL_REACT_LIVE_BGAPI_COMMAND=status
ESL_REACT_LIVE_BGAPI_ARGS=
ESL_REACT_LIVE_BGAPI_TIMEOUT=20

# Enable only when you want to validate public runner lifecycle truth while
# receiving a live event and completing one safe bgapi job.
ESL_REACT_LIVE_RUNNER_BGAPI_EVENT_TEST=0
ESL_REACT_LIVE_RUNNER_BGAPI_EVENT_NAME=HEARTBEAT
ESL_REACT_LIVE_RUNNER_BGAPI_EVENT_TIMEOUT=25
# ESL_REACT_LIVE_RUNNER_BGAPI_EVENT_TRIGGER_API=
ESL_REACT_LIVE_RUNNER_BGAPI_COMMAND=msleep
ESL_REACT_LIVE_RUNNER_BGAPI_ARGS=1000
ESL_REACT_LIVE_RUNNER_BGAPI_TIMEOUT=20

# Enable only when your lab target can safely automate transport disruption and
# restoration while validating event delivery and one safe bgapi job after
# reconnect on the public runner seam.
ESL_REACT_LIVE_RUNNER_RECONNECT_BGAPI_EVENT_TEST=0
ESL_REACT_LIVE_RUNNER_RECONNECT_BGAPI_EVENT_NAME=HEARTBEAT
ESL_REACT_LIVE_RUNNER_RECONNECT_BGAPI_EVENT_TIMEOUT=25
# ESL_REACT_LIVE_RUNNER_RECONNECT_BGAPI_EVENT_TRIGGER_API=
ESL_REACT_LIVE_RUNNER_RECONNECT_BGAPI_COMMAND=status
ESL_REACT_LIVE_RUNNER_RECONNECT_BGAPI_ARGS=
ESL_REACT_LIVE_RUNNER_RECONNECT_BGAPI_TIMEOUT=20

# Enable only when you want to validate that a genuinely pending bgapi job
# stays tracked across a live reconnect boundary on the public runner seam.
# The default fault mode force-closes the runner transport locally so the live
# FreeSWITCH target keeps processing the pending bgapi job during reconnect.
# An external ESL-control fault path remains available when your lab wants it.
ESL_REACT_LIVE_RUNNER_PENDING_BGAPI_RECONNECT_TEST=0
ESL_REACT_LIVE_RUNNER_PENDING_BGAPI_COMMAND=msleep
ESL_REACT_LIVE_RUNNER_PENDING_BGAPI_ARGS=15000
ESL_REACT_LIVE_RUNNER_PENDING_BGAPI_TIMEOUT=45
ESL_REACT_LIVE_RUNNER_PENDING_BGAPI_DISCONNECT_TIMEOUT=20
ESL_REACT_LIVE_RUNNER_PENDING_BGAPI_RECONNECT_TIMEOUT=30
ESL_REACT_LIVE_RUNNER_PENDING_BGAPI_DISRUPT_SETTLE_SECONDS=1
ESL_REACT_LIVE_RUNNER_PENDING_BGAPI_RESTORE_SETTLE_SECONDS=1
ESL_REACT_LIVE_RUNNER_PENDING_BGAPI_FAULT_MODE=client_transport_close
ESL_REACT_LIVE_RUNNER_PENDING_BGAPI_FAULT_API='reload mod_event_socket'
ESL_REACT_LIVE_RUNNER_PENDING_BGAPI_FAULT_API_TIMEOUT=6
# ESL_REACT_LIVE_RUNNER_PENDING_BGAPI_DISRUPT_COMMAND=
# ESL_REACT_LIVE_RUNNER_PENDING_BGAPI_RESTORE_COMMAND=

# Enable only when your lab can safely emit one supported semantic event that
# the runtime truthfully maps today.
ESL_REACT_LIVE_RUNNER_SEMANTIC_TEST=0
ESL_REACT_LIVE_RUNNER_SEMANTIC_EVENT_NAME=CHANNEL_HANGUP_COMPLETE
ESL_REACT_LIVE_RUNNER_SEMANTIC_TIMEOUT=30
# ESL_REACT_LIVE_RUNNER_SEMANTIC_TRIGGER_API=

# Enable only when you want to observe heartbeat/liveness degradation and probe-driven recovery
# on the public runner seam. This should be run against a relatively quiet target.
ESL_REACT_LIVE_RUNNER_LIVENESS_TEST=0
ESL_REACT_LIVE_LIVENESS_INTERVAL_SECONDS=0.5
ESL_REACT_LIVE_LIVENESS_TIMEOUT_SECONDS=0.1
ESL_REACT_LIVE_LIVENESS_DEGRADE_TIMEOUT=10
ESL_REACT_LIVE_LIVENESS_RECOVERY_TIMEOUT=10
ESL_REACT_LIVE_LIVENESS_API_TIMEOUT=5

# Enable only when your lab target can safely become silent without immediately closing the
# connection, so the second-miss heartbeat dead/reconnect path can be observed.
ESL_REACT_LIVE_RUNNER_HEARTBEAT_RECONNECT_TEST=0
# ESL_REACT_LIVE_HEARTBEAT_DEADPATH_DISRUPT_COMMAND=
# ESL_REACT_LIVE_HEARTBEAT_DEADPATH_RESTORE_COMMAND=
ESL_REACT_LIVE_HEARTBEAT_DEADPATH_INTERVAL_SECONDS=0.5
ESL_REACT_LIVE_HEARTBEAT_DEADPATH_TIMEOUT_SECONDS=0.1
ESL_REACT_LIVE_HEARTBEAT_DEADPATH_DEGRADE_TIMEOUT=10
ESL_REACT_LIVE_HEARTBEAT_DEADPATH_RECONNECT_OBSERVE_TIMEOUT=15
ESL_REACT_LIVE_HEARTBEAT_DEADPATH_RECOVERY_TIMEOUT=20
ESL_REACT_LIVE_HEARTBEAT_DEADPATH_API_TIMEOUT=5

# Enable only for staging/lab manual reconnect recovery checks.
ESL_REACT_LIVE_MANUAL_RECONNECT_TEST=0
ESL_REACT_LIVE_MANUAL_DISCONNECT_TIMEOUT=45
ESL_REACT_LIVE_MANUAL_RECONNECT_TIMEOUT=60
ESL_REACT_LIVE_POST_RECONNECT_EVENT_TIMEOUT=25

# Enable only for staging/lab manual reconnect + post-reconnect api() checks.
ESL_REACT_LIVE_MANUAL_RECONNECT_API_TEST=0
ESL_REACT_LIVE_POST_RECONNECT_API_COMMAND=status
ESL_REACT_LIVE_POST_RECONNECT_API_TIMEOUT=6

# Enable only for staging/lab manual reconnect + post-reconnect bgapi() checks.
ESL_REACT_LIVE_MANUAL_RECONNECT_BGAPI_TEST=0
ESL_REACT_LIVE_POST_RECONNECT_BGAPI_COMMAND=status
ESL_REACT_LIVE_POST_RECONNECT_BGAPI_ARGS=
ESL_REACT_LIVE_POST_RECONNECT_BGAPI_TIMEOUT=20
