{
    "name": "apntalk/esl-react",
    "description": "ReactPHP-native inbound FreeSWITCH ESL runtime for PHP — async connection management, command dispatch, event streaming, health, and reconnect supervision",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "freeswitch",
        "esl",
        "event-socket",
        "reactphp",
        "async",
        "telephony"
    ],
    "authors": [
        {
            "name": "RA",
            "email": "ronniel.castanito@apntelecom.com"
        }
    ],
    "require": {
        "php": "^8.3",
        "apntalk/esl-core": "^0.2",
        "react/event-loop": "^1.5",
        "react/promise": "^3.2",
        "react/socket": "^1.16"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5 || ^11.0",
        "phpstan/phpstan": "^1.11",
        "friendsofphp/php-cs-fixer": "^3.58"
    },
    "autoload": {
        "psr-4": {
            "Apntalk\\EslReact\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Apntalk\\EslReact\\Tests\\": "tests/"
        }
    },
    "homepage": "https://github.com/apn-ra/esl-react",
    "support": {
        "issues": "https://github.com/apn-ra/esl-react/issues",
        "source": "https://github.com/apn-ra/esl-react"
    },
    "scripts": {
        "test": "phpunit --no-coverage",
        "test-unit": "phpunit --no-coverage --testsuite Unit",
        "test-contract": "phpunit --no-coverage --testsuite Contract",
        "test-integration": "phpunit --no-coverage --testsuite Integration",
        "analyse": "phpstan analyse",
        "cs-fix": "php-cs-fixer fix",
        "cs-check": "php-cs-fixer fix --dry-run --diff --sequential",
        "check": [
            "@cs-check",
            "@analyse",
            "@test"
        ]
    },
    "config": {
        "sort-packages": true,
        "optimize-autoloader": true
    },
    "minimum-stability": "stable"
}
